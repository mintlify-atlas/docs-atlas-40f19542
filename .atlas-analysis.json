  "keyFeatures": [
    "Cross-platform speech recognition for iOS, Android, and Web",
    "Web Speech API compatibility with polyfill support",
    "React hooks API (useSpeechRecognitionEvent)",
    "Continuous and interim results recognition",
    "On-device recognition support (no network required)",
    "Audio recording and file transcription",
    "Volume metering with real-time events",
    "Language detection (Android 14+ with on-device recognition)",
    "Contextual strings for improved accuracy",
    "Full TypeScript support"
  ],
